<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <Import Project="$(MSBuildThisFileDirectory)Microsoft.Xaml.Tooling.targets" />

    <PropertyGroup>
        <ResolveReferencesDependsOn Condition="'$(ProjectReunionVerifyWinrtRuntimeVersion)'!='false' and '$(MSBuildProjectExtension)'=='.csproj'">
            $(ResolveReferencesDependsOn);ProjectReunionVerifyWinrtRuntimeVersion
        </ResolveReferencesDependsOn>
    </PropertyGroup>
    
    <Target Name="ProjectReunionVerifyWinrtRuntimeVersion" DependsOnTargets="ResolveAssemblyReferences">
        <ItemGroup>
            <_RuntimeCopyLocalItemsWithNuGetPackageVersion Include="@(RuntimeCopyLocalItems->HasMetadata('NuGetPackageVersion'))" />
            <_WinrtRuntimeCompatible Include="@(_RuntimeCopyLocalItemsWithNuGetPackageVersion)" Condition="'%(Filename)%(Extension)'=='WinRT.Runtime.dll' and %(NuGetPackageVersion)&gt;1.6" />
            <_ReferenceWithAssemblyVersion Include="@(Reference->HasMetadata('AssemblyVersion'))" />
            <_WinrtRuntimeIncompatible Include="@(_ReferenceWithAssemblyVersion)" Condition="'%(Filename)%(Extension)'=='WinRT.Runtime.dll' and %(AssemblyVersion)&lt;1.6" />
        </ItemGroup>
        <Error Condition="'@(_WinrtRuntimeIncompatible)'!='' and '@(_WinrtRuntimeCompatible)'==''"
            Text="This version of Project Reunion requires WinRT.Runtime.dll version 1.6 or greater. 
    Please update to .NET SDK 5.0.213 or 5.0.407 or later.
    Or add a temporary Microsoft.Windows.SDK.NET.Ref reference of version 10.0.*.24 or later.
    For example,
        &lt;PropertyGroup&gt;
            &lt;WindowsSdkPackageVersion&gt;10.0.&lt;Target Windows SDK Build Number&gt;.24&lt;/WindowsSdkPackageVersion&gt;
        &lt;/PropertyGroup&gt;
" />
    </Target>

</Project>
