<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RadaeeWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RadaeeWinUI"
    xmlns:controls="using:RadaeeWinUI.Controls"
    xmlns:pdfview="using:RadaeeWinUI.Controls.PDFView"
    xmlns:models="using:RadaeeWinUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Radaee PDF Viewer">



    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Icon="OpenFile" Label="Open" Click="OpenDocument_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="ZoomIn" Label="Zoom In" Click="ZoomIn_Click"/>
            <AppBarButton Icon="ZoomOut" Label="Zoom Out" Click="ZoomOut_Click"/>
            <AppBarButton Icon="Zoom" Label="Fit Width" Click="FitWidth_Click"/>
            <AppBarButton x:Name="BtnOutline" Icon="OutlineStar" Label="Outline" Click="Outline_Click" Visibility="Collapsed"/>
            <AppBarButton x:Name="BtnAttachment" Icon="Attach" Label="Attachment" Click="Attachment_Click" Visibility="Collapsed"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Find" Label="Search" Click="Search_Click"/>
            <AppBarButton Label="View Mode">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Single Page" Click="ViewMode_SinglePage_Click"/>
                        <MenuFlyoutItem Text="Vertical Continuous" Click="ViewMode_VerticalContinuous_Click"/>
                        <MenuFlyoutItem Text="Horizontal Continuous" Click="ViewMode_HorizontalContinuous_Click"/>
                        <MenuFlyoutItem Text="Dual Page" Click="ViewMode_DualPage_Click"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
        </CommandBar>

        <controls:AnnotationToolbar x:Name="AnnotationToolbar" Grid.Row="1" Visibility="Collapsed"/>
        <controls:SearchToolbar x:Name="SearchToolbar" Grid.Row="1" Visibility="Collapsed"/>

        <Grid Grid.Row="2">
            <TextBlock x:Name="EmptyMessage"
                       Text="Open a PDF document to start viewing"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="Gray"/>



            <ContentControl x:Name="PDFViewContainer"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Visibility="Collapsed"/>
        </Grid>

        <Grid Grid.Row="3" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Padding="10,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <Button Content="Previous" Click="PreviousPage_Click">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Left"/>
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Content="Next" Click="NextPage_Click">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Right"/>
                    </Button.KeyboardAccelerators>
                </Button>
                <Border BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Padding="10,5" 
                        Margin="10,0">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="Page:" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PageNumberText" 
                                   Text="0"
                                   VerticalAlignment="Center" 
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="/" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TotalPagesText" 
                                   Text="0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="Zoom:" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ZoomLevelText" 
                                   Text="100%"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

