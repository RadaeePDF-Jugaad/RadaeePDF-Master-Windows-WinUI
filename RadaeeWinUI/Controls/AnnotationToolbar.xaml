<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="RadaeeWinUI.Controls.AnnotationToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:RadaeeWinUI.Models"
    mc:Ignorable="d">

    <StackPanel Orientation="Horizontal" Spacing="8" Padding="8">
        <TextBlock Text="Annotation Tools:" VerticalAlignment="Center" Margin="0,0,8,0"/>

        <Button Content="Select" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.Select}" ToolTipService.ToolTip="Select text"/>
        <Button Content="Highlight" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.Highlight}" ToolTipService.ToolTip="Highlight text"/>
        <Button Content="Underline" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.Underline}" ToolTipService.ToolTip="Underline text"/>
        <Button Content="Strikeout" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.Strikeout}" ToolTipService.ToolTip="Strikeout text"/>
        
        <Border Width="1" Background="Gray" Margin="4,0"/>
        <Button Content="Text Note" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.TextNote}" ToolTipService.ToolTip="Add text note"/>
        <Button Content="Rectangle" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.Rectangle}" ToolTipService.ToolTip="Draw rectangle"/>
        <Button Content="Ellipse" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.Ellipse}" ToolTipService.ToolTip="Draw ellipse"/>
        <Button Content="Line" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.Line}" ToolTipService.ToolTip="Draw line"/>
        <Button Content="Ink" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="{x:Bind models:AnnotationType.Ink}" ToolTipService.ToolTip="Freehand drawing"/>
        
        <Border Width="1" Background="Gray" Margin="4,0"/>
        
        <TextBlock Text="Color:" VerticalAlignment="Center" Margin="8,0,4,0"/>
        <ComboBox x:Name="ColorPicker" SelectedIndex="0" Width="100">
            <ComboBoxItem Content="Red" Tag="#FFFF0000"/>
            <ComboBoxItem Content="Blue" Tag="#FF0000FF"/>
            <ComboBoxItem Content="Green" Tag="#FF00FF00"/>
            <ComboBoxItem Content="Yellow" Tag="#FFFFFF00"/>
            <ComboBoxItem Content="Black" Tag="#FF000000"/>
        </ComboBox>
        
        <TextBlock Text="Width:" VerticalAlignment="Center" Margin="8,0,4,0"/>
        <Slider x:Name="StrokeWidthSlider" Minimum="1" Maximum="10" Value="{x:Bind ViewModel.StrokeWidth, Mode=TwoWay}" Width="100" VerticalAlignment="Center"/>
        <TextBlock Text="{x:Bind StrokeWidthSlider.Value, Mode=OneWay}" VerticalAlignment="Center" Width="30"/>
        
        <Border Width="1" Background="Gray" Margin="4,0"/>
        
        <Button Content="Delete" Command="{x:Bind ViewModel.DeleteAnnotationCommand}" ToolTipService.ToolTip="Delete selected annotation"/>
    </StackPanel>
</UserControl>
