<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="RadaeeWinUI.Controls.GraphicAnnotDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Edit Graphic Annotation"
    PrimaryButtonText="OK"
    SecondaryButtonText="Delete"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    SecondaryButtonClick="OnDeleteButtonClick">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
        <StackPanel Spacing="16" MinWidth="400" Padding="0,0,12,0">
            
            <!-- Stroke Width -->
            <StackPanel Spacing="8">
                <TextBlock Text="Stroke Width:" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="*,Auto">
                    <Slider x:Name="StrokeWidthSlider"
                            Grid.Column="0"
                            Minimum="0.5"
                            Maximum="10"
                            StepFrequency="0.5"
                            TickFrequency="0.5"
                            TickPlacement="BottomRight"
                            ValueChanged="OnStrokeWidthChanged"/>
                    <TextBlock Grid.Column="1" 
                               x:Name="StrokeWidthText"
                               Text="2.0"
                               Width="40"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- Stroke Color -->
            <StackPanel Spacing="8">
                <TextBlock Text="Stroke Color:" FontWeight="SemiBold"/>
                <ColorPicker x:Name="StrokeColorPicker"
                             ColorSpectrumShape="Ring"
                             IsMoreButtonVisible="False"
                             IsColorSliderVisible="True"
                             IsColorChannelTextInputVisible="True"
                             IsHexInputVisible="True"
                             IsAlphaEnabled="False"/>
            </StackPanel>

            <!-- Stroke Transparency -->
            <StackPanel Spacing="8">
                <TextBlock Text="Stroke Transparency:" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="*,Auto">
                    <Slider x:Name="StrokeTransparencySlider"
                            Grid.Column="0"
                            Minimum="0"
                            Maximum="255"
                            StepFrequency="1"
                            TickFrequency="25.5"
                            TickPlacement="BottomRight"
                            ValueChanged="OnStrokeTransparencyChanged"/>
                    <TextBlock Grid.Column="1" 
                               x:Name="StrokeTransparencyText"
                               Text="100%"
                               Width="50"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- Line Style -->
            <StackPanel Spacing="8">
                <TextBlock Text="Line Style:" FontWeight="SemiBold"/>
                <ComboBox x:Name="LineStyleComboBox" 
                          HorizontalAlignment="Stretch"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Solid" Tag="0"/>
                    <ComboBoxItem Content="Dashed" Tag="1"/>
                    <ComboBoxItem Content="Beveled" Tag="2"/>
                    <ComboBoxItem Content="Inset" Tag="3"/>
                    <ComboBoxItem Content="Underline" Tag="4"/>
                </ComboBox>
            </StackPanel>

            <!-- Fill Color -->
            <StackPanel Spacing="8">
                <TextBlock Text="Fill Color:" FontWeight="SemiBold"/>
                <ColorPicker x:Name="FillColorPicker"
                             ColorSpectrumShape="Ring"
                             IsMoreButtonVisible="False"
                             IsColorSliderVisible="True"
                             IsColorChannelTextInputVisible="True"
                             IsHexInputVisible="True"
                             IsAlphaEnabled="False"/>
            </StackPanel>

            <!-- Fill Transparency -->
            <StackPanel Spacing="8">
                <TextBlock Text="Fill Transparency:" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="*,Auto">
                    <Slider x:Name="FillTransparencySlider"
                            Grid.Column="0"
                            Minimum="0"
                            Maximum="255"
                            StepFrequency="1"
                            TickFrequency="25.5"
                            TickPlacement="BottomRight"
                            ValueChanged="OnFillTransparencyChanged"/>
                    <TextBlock Grid.Column="1" 
                               x:Name="FillTransparencyText"
                               Text="0%"
                               Width="50"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
