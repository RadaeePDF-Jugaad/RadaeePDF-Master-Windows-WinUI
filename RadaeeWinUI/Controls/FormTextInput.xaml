<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="RadaeeWinUI.Controls.FormTextInput"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border x:Name="InputBorder"
            Background="{ThemeResource TextControlBackground}"
            BorderBrush="{ThemeResource TextControlBorderBrush}"
            BorderThickness="2"
            CornerRadius="4"
            Padding="4">
        <Grid>
            <TextBox x:Name="InputTextBox"
                     BorderThickness="0"
                     Background="Transparent"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     LostFocus="InputTextBox_LostFocus"
                     Loaded="InputTextBox_Loaded"
                     KeyDown="InputTextBox_KeyDown"
                     Visibility="Visible"/>
            <PasswordBox x:Name="InputPasswordBox"
                         BorderThickness="0"
                         Background="Transparent"
                         LostFocus="InputPasswordBox_LostFocus"
                         Loaded="InputPasswordBox_Loaded"
                         KeyDown="InputPasswordBox_KeyDown"
                         Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>
