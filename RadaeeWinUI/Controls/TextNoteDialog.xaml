<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="RadaeeWinUI.Controls.TextNoteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Edit Text Note"
    PrimaryButtonText="OK"
    SecondaryButtonText="Delete"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    SecondaryButtonClick="OnDeleteButtonClick">

    <StackPanel Spacing="12" MinWidth="400">
        <TextBlock Text="Subject:" FontWeight="SemiBold"/>
        <TextBox x:Name="SubjectTextBox"
                 PlaceholderText="Enter subject..."
                 TextWrapping="Wrap"/>

        <TextBlock Text="Content:" FontWeight="SemiBold" Margin="0,8,0,0"/>
        <TextBox x:Name="ContentTextBox" 
                 PlaceholderText="Type your note here..."
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Height="150"/>
    </StackPanel>
</ContentDialog>
