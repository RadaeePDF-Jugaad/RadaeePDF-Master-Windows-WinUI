<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="RadaeeWinUI.Controls.OutlineDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:RadaeeWinUI.Controls"
    mc:Ignorable="d"
    Title="Table of Contents"
    CloseButtonText="Close"
    DefaultButton="Close">

    <Grid MinWidth="400" MinHeight="500" MaxHeight="700">
        <TreeView x:Name="OutlineTreeView"
                  ItemInvoked="OutlineTreeView_ItemInvoked"
                  SelectionMode="Single">
            <TreeView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Content.Title}" 
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</ContentDialog>
